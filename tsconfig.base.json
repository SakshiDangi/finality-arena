{
  "compilerOptions": {
    "target": "ES2022",
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "esModuleInterop": true,
    "verbatimModuleSyntax": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true
  }
}